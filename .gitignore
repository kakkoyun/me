# Hugo default output directory
/public

## OS Files
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# OSX
.DS_Store

# **/themes/
resources
demo/
.hugo/*
!.hugo/version

# Local Netlify folder
.netlify

# Obsidian
.obsidian/

# Hugo
.hugo_build.lock

# Lighthouse CI local run output
.lighthouseci/

# Node
node_modules/

# Agentic programming
tmp/!CLAUDE.md
!CLAUDE.md
.omc

# Track repo-committed Claude config (overrides global .gitignore_global .claude/* rule)
!.claude/settings.json
!.claude/skills/
!.claude/skills/**
!.claude/commands/
!.claude/commands/*.md

# Vale styles: commit our own rules under styles/Slop/ and styles/config/,
# ignore third-party packages fetched via `vale sync`.
styles/*
!styles/Slop/
!styles/Slop/**
!styles/config/
!styles/config/**

# .mcp.json is committed: every server MUST use op:// references, never literal secrets.
!.mcp.json

# Things3 Task Migration
.migration/

# Newsletter sidecar briefs (raw aggregation data, not for committing)
content/newsletter/the-unwind/.brief-*.md
